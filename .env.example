# ========================================
# Server Configuration
# ========================================
# PORT is injected automatically by most hosts (e.g. Railway). Default 3000 locally.
PORT=3000
NODE_ENV=production

# ========================================
# Upload Limits — build-time vars, set BEFORE the build to take effect.
# ========================================
# Deployment mode preset:
#   unset/empty  -> local (plug-and-play): 30 files / 50 MB
#   server       -> deployed/paid host:    10 files / 20 MB
# NEXT_PUBLIC_HOST=server

# Fine override (wins over the preset above). Leave empty to use the preset.
# NEXT_PUBLIC_MAX_FILES=10
# NEXT_PUBLIC_MAX_FILE_MB=20

# ========================================
# Cleanup Configuration
# ========================================
# Interval for cleanup job in minutes (runs every N minutes)
CLEANUP_INTERVAL=15

# Time To Live for files in seconds (3600 = 1 hour)
# Files older than this are automatically deleted
FILE_TTL=3600

# ========================================
# Runtime / abuse protection (server-side, runtime — no rebuild needed)
# Defaults follow NEXT_PUBLIC_HOST: "server" is conservative, otherwise local.
# ========================================
# Concurrent jobs processed at once (local 2 / server 1)
# MAX_CONCURRENT_JOBS=2

# Max jobs queued before new ones are rejected with 503 (local 30 / server 8)
# MAX_QUEUE=30

# Rate limit: max job creations per IP per window (local 30 / server 5)
# RATE_LIMIT_MAX=30
# RATE_LIMIT_WINDOW_MIN=5

# libvips threads per image op (local 2 / server 1)
# SHARP_CONCURRENCY=2

# Same-origin guard on mutating API routes. Set false to allow direct API use.
# ENFORCE_SAME_ORIGIN=true
# Extra allowed origins (comma-separated hostnames), e.g. example.com,app.example.com
# ALLOWED_ORIGINS=
# Behind a proxy/custom domain (Railway, Cloudflare), the public host arrives in
# x-forwarded-host. Set true ONLY if a trusted proxy sets it (it is spoofable
# when the app is directly exposed). Alternative: list the domain in ALLOWED_ORIGINS.
# TRUST_FORWARDED_HOST=true

# ========================================
# Legal pages (build-time)
# ========================================
# Terms/Privacy pages + footer links are OFF by default (the bundled docs are
# written for Aurora33). Set to "on" only if you operate under those documents
# (the official hosted instance does). You are responsible for your own legal
# compliance.
# NEXT_PUBLIC_LEGAL=on
